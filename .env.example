# ==========================================
# ZVELTIO ENVIRONMENT
# ==========================================

# Database (Postgres 18 + PGVector)
POSTGRES_USER=zveltio
POSTGRES_PASSWORD=zveltio
POSTGRES_DB=zveltio
POSTGRES_PORT_HOST=5432

# Connection Pooler (PgDog)
PGDOG_PORT_HOST=6432

# Valkey (Modern Redis Fork)
VALKEY_PASSWORD=zveltio
VALKEY_PORT_HOST=6379

# Storage (SeaweedFS)
STORAGE_S3_PORT=8333
STORAGE_FILER_PORT=8888

# Prometheus (Metrics)
PROMETHEUS_PORT=9090

# Grafana (Monitoring Dashboards)
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=         # Required: set a strong password for Grafana

# Server
PORT=3000
HOST=0.0.0.0

# Security
JWT_SECRET=change-this-in-production-minimum-32-chars
BETTER_AUTH_SECRET=change-this-in-production-minimum-32-chars
BETTER_AUTH_URL=http://localhost:3000
SECRET_KEY=change-this-in-production-minimum-64-chars

# Auth providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# Extensions active (comma-separated)
ZVELTIO_EXTENSIONS=workflow/approvals,workflow/checklists,ai/core-ai,content/page-builder

# Extensions external path (for compliance or custom extensions)
# ZVELTIO_EXTENSIONS_PATH=/opt/zveltio-extensions

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# S3 Access (for SeaweedFS - optional, not required by default)
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=http://localhost:8333

# Observability (optional — leave empty to disable)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=zveltio-engine

# ── Extension signing (S1-01 + S4-05) ────────────────────────────────────
# Engine refuses unsigned extension archives when set to "true". Default
# false until the registry has been provisioned with its keypair.
REQUIRE_EXTENSION_SIGNATURES=false

# Trusted public keys for verifying signed extension archives. JSON array
# of { keyId, publicKeyHex } entries. The registry's pubkey goes here so
# the engine recognizes signatures issued by registry.zveltio.com.
#
# Current production registry key (wave 36, 2026-05-17):
REGISTRY_PUBLIC_KEYS_JSON=[{"keyId":"registry-prod-2026","publicKeyHex":"7c9182ab9015d40f9199b7e282357e3ea21d6697c2c51a7c43ca9dfc9a7fc123"}]
