# ============================================================
# ZVELTIO ENVIRONMENT (.env)
# ============================================================
#
# Generate strong secrets BEFORE first start. Examples:
#   openssl rand -base64 32         # for passwords (POSTGRES, VALKEY, GRAFANA, S3)
#   openssl rand -hex 32            # for keys (BETTER_AUTH_SECRET, FIELD_ENCRYPTION_KEY, …)
#
# Compose refuses to start with empty :?ERROR vars below — that is
# intentional, NOT a bug. Fill them in.
# ============================================================

# ── PostgreSQL (Postgres 18 + PGVector) ─────────────────────
POSTGRES_USER=zveltio
POSTGRES_PASSWORD=        # REQUIRED — `openssl rand -base64 32`
POSTGRES_DB=zveltio
POSTGRES_PORT_HOST=5432

# Connection Pooler (PgDog)
PGDOG_PORT_HOST=6432

# ── Valkey (Modern Redis Fork) ───────────────────────────────
VALKEY_PASSWORD=          # REQUIRED — `openssl rand -base64 32`
VALKEY_PORT_HOST=6379

# ── Object Storage (SeaweedFS) ───────────────────────────────
# Ports stay inside the compose network unless STORAGE_EXPOSE_PORTS=true.
# Default is internal-only — SeaweedFS has weak default auth and should
# never be publicly reachable.
S3_ACCESS_KEY=            # REQUIRED — `openssl rand -hex 16`
S3_SECRET_KEY=            # REQUIRED — `openssl rand -hex 32`
S3_PUBLIC_URL=http://localhost:8333

# ── Observability ────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=   # REQUIRED — `openssl rand -base64 24`

# ── Engine ───────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# ── Security: auth + crypto keys ─────────────────────────────
# BETTER_AUTH_SECRET signs session cookies AND keys field encryption.
# Rotating it invalidates every session and renders encrypted secrets
# (LDAP bind password, webhook signing secret, …) un-decryptable, so
# rotate only via a planned migration.
BETTER_AUTH_SECRET=       # REQUIRED — `openssl rand -hex 32`
BETTER_AUTH_URL=http://localhost:3000

# Per-field AES-256-GCM key for collection fields marked `encrypted: true`
# and for the LDAP bindPassword / SAML privateKey / webhook secrets at rest.
# Unset = those fields are stored in plaintext (loud warning at boot).
FIELD_ENCRYPTION_KEY=     # `openssl rand -hex 32`

# Argon2id tuning. Defaults (4 MB / 3 iter) keep create-god usable on
# small VMs. OWASP recommends ≥19 MB (19456) for production hardware.
ARGON_MEMORY_COST_KIB=19456
ARGON_TIME_COST=3

# CORS — comma-separated. Required in production; the engine warns at
# boot if NODE_ENV=production and this is empty.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Cross-domain auth (Studio on a different origin than the engine):
# switches the session cookie to SameSite=None; Secure. HTTPS-only.
CROSS_DOMAIN_AUTH=false

# Trust X-Forwarded-For / X-Real-IP when running behind nginx/Cloudflare.
# DO NOT set to true on hosts directly exposed to the internet — clients
# can spoof those headers to bypass per-IP rate limits.
TRUSTED_PROXY=false

# ── Retention (purged nightly at 03:00) ──────────────────────
# 0 = keep forever.
REQUEST_LOG_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=365

# ── OAuth / social providers (optional) ──────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# ── SAML / LDAP SSO (optional) ───────────────────────────────
# In production, /ext/auth/ldap/login refuses non-ldaps:// URLs unless
# ALLOW_INSECURE_LDAP=true is set explicitly. Leave false on real
# deployments — ldap:// (389) ships credentials in cleartext.
ALLOW_INSECURE_LDAP=false

# ── Billing / Stripe (optional, billing extension) ───────────
STRIPE_WEBHOOK_SECRET=

# ── Mail (optional, communications/mail extension) ───────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Demo mode ────────────────────────────────────────────────
# DEMO_MODE=true advertises throwaway credentials on /api/health.
# The engine refuses to surface them when NODE_ENV=production unless
# DEMO_MODE_ALLOW_IN_PROD=true is explicitly set — defence in depth
# for the operator-forgot-to-toggle case.
DEMO_MODE=false
DEMO_MODE_ALLOW_IN_PROD=false

# ── Extensions ───────────────────────────────────────────────
ZVELTIO_EXTENSIONS=workflow/approvals,workflow/checklists,ai,content/page-builder

# Extensions external path (for compliance or custom extensions)
# ZVELTIO_EXTENSIONS_PATH=/opt/zveltio-extensions

# Engine refuses unsigned extension archives when set to "true".
# Default false until the registry has been provisioned with its keypair.
REQUIRE_EXTENSION_SIGNATURES=false

# Trusted public keys for verifying signed extension archives. JSON array
# of { keyId, publicKeyHex } entries. The registry's pubkey goes here so
# the engine recognises signatures issued by registry.zveltio.com.
REGISTRY_PUBLIC_KEYS_JSON=[{"keyId":"registry-prod-2026","publicKeyHex":"7c9182ab9015d40f9199b7e282357e3ea21d6697c2c51a7c43ca9dfc9a7fc123"}]

# ── Observability (optional) ─────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=zveltio-engine
