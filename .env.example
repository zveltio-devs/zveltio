# Database (required)
DATABASE_URL=postgresql://postgres:password@localhost:5432/zveltio

# Cache (optional, Redis/Valkey)
REDIS_URL=redis://localhost:6379

# Storage (optional, S3-compatible)
S3_ENDPOINT=http://localhost:8333
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=zveltio

# Server
PORT=3000
HOST=0.0.0.0

# Security
JWT_SECRET=change-this-in-production-minimum-32-chars
BETTER_AUTH_SECRET=change-this-in-production-minimum-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Auth providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# Extensions active (comma-separated)
ZVELTIO_EXTENSIONS=workflow/approvals,workflow/checklists,ai/core-ai,content/page-builder

# Extensions external path (for compliance or custom extensions)
# ZVELTIO_EXTENSIONS_PATH=/opt/zveltio-extensions

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
