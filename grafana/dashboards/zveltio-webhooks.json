          "editorMode": "code",
          "expr": "rate(webhook_deliveries_total{status=\"success\"}[5m]) / rate(webhook_deliveries_total[5m])",
          "legendFormat": "Success Rate",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Delivery Success Rate",
      "type": "gauge"
    },
    {
      "datasource": {
        "type": "prometheus",
