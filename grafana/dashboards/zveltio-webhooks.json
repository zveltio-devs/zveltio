        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "rate(webhook_deliveries_total{status=\"failed\"}[5m])",
          "legendFormat": "Failed/s",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Failed Deliveries",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
