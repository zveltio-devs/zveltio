{
  "name": "@zveltio/sdk",
  "version": "1.0.0-alpha.79",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./extension": {
      "types": "./dist/extension/index.d.ts",
      "import": "./dist/extension/index.js"
    },
    "./codegen": {
      "types": "./dist/schema-codegen.d.ts",
      "import": "./dist/schema-codegen.js"
    },
    "./validate": {
      "types": "./dist/validate/index.d.ts",
      "import": "./dist/validate/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test --preload ./src/tests/setup.ts"
  },
  "dependencies": {
    "idb": "^8.0.0"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.2.5",
    "hono": "^4.12.5",
    "kysely": "^0.27.0",
    "typescript": "^5.4.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zveltio-devs/zveltio.git"
  }
}
