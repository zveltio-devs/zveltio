{
  "name": "@zveltio/sdk",
  "version": "3.0.0-beta.6",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./extension": {
      "types": "./dist/extension/index.d.ts",
      "import": "./dist/extension/index.js"
    },
    "./codegen": {
      "types": "./dist/schema-codegen.d.ts",
      "import": "./dist/schema-codegen.js"
    },
    "./validate": {
      "types": "./dist/validate/index.d.ts",
      "import": "./dist/validate/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    },
    "./publish": {
      "types": "./dist/publish/index.d.ts",
      "import": "./dist/publish/index.js"
    },
    "./build": {
      "types": "./dist/build/index.d.ts",
      "import": "./dist/build/index.js"
    },
    "./studio": {
      "types": "./dist/studio/index.d.ts",
      "import": "./dist/studio/index.js"
    },
    "./ddl": {
      "types": "./dist/ddl/index.d.ts",
      "import": "./dist/ddl/index.js"
    },
    "./rpc": {
      "types": "./dist/rpc/index.d.ts",
      "import": "./dist/rpc/index.js"
    },
    "./offline": {
      "types": "./dist/offline/index.d.ts",
      "import": "./dist/offline/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test --preload ./src/tests/setup.ts"
  },
  "dependencies": {
    "idb": "^8.0.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.0.0",
    "@types/pg": "^8.11.0",
    "fake-indexeddb": "^6.2.5",
    "hono": "^4.12.5",
    "kysely": "^0.27.0",
    "pg": "^8.13.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "@testcontainers/postgresql": "^11.0.0",
    "pg": "^8.13.0"
  },
  "peerDependenciesMeta": {
    "@testcontainers/postgresql": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zveltio-devs/zveltio.git"
  }
}
