{
  "name": "@zveltio/studio",
  "version": "3.0.0-beta.32",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 5173",
    "sync-ext": "bun scripts/sync-extensions.ts",
    "predev": "bun scripts/merge-extension-messages.ts && paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "prebuild": "bun scripts/sync-extensions.ts && bun scripts/merge-extension-messages.ts && paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "build": "vite build",
    "preview": "vite preview",
    "embed": "cp -r dist ../engine/src/studio-dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "i18n:merge": "bun scripts/merge-extension-messages.ts",
    "i18n:compile": "bun run i18n:merge && paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide"
  },
  "dependencies": {
    "@inlang/paraglide-js": "^2.18.0",
    "@lucide/svelte": "^0.577.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.5.0",
    "@tiptap/core": "^2.27.2",
    "@tiptap/extension-image": "^2.11.0",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-table": "^2.11.0",
    "@tiptap/extension-table-cell": "^2.11.0",
    "@tiptap/extension-table-header": "^2.11.0",
    "@tiptap/extension-table-row": "^2.11.0",
    "@tiptap/starter-kit": "^2.11.0",
    "@types/leaflet": "^1.9.0",
    "@zveltio/sdk": "workspace:*",
    "d3-scale": "^4.0.2",
    "daisyui": "^5.0.0",
    "dompurify": "3.4.11",
    "layerchart": "^1.0.13",
    "leaflet": "^1.9.4",
    "svelte": "^5.0.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^22.10.0",
    "@vitest/ui": "^4.1.6",
    "jsdom": "^29.1.1",
    "typescript": "^5.4.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.6"
  }
}
