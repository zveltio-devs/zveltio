{
  "name": "@zveltio/engine",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "dev": "bun --watch src/index.ts",
    "monitor": "bun watch/index.js",
    "all": "bun dev & bun monitor",
    "start": "bun dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:init": "bun scripts/init-db.ts",
    "cdc:setup": "bun scripts/setup-cdc.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:unit": "bun test src/tests/unit",
    "test:integration": "bun test src/tests/integration"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@hono/zod-validator": "^0.7.6",
    "better-auth": "^1.3.34",
    "casbin": "^5.30.0",
    "expr-eval": "^2.0.2",
    "graphql": "^16.9.0",
    "graphql-yoga": "^5.10.4",
    "hono": "^4.4.0",
    "nanoid": "^5.0.7",
    "pdfkit": "^0.15.0",
    "ioredis": "^5.3.2",
    "kysely": "^0.27.6",
    "pg": "^8.11.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.4.0"
  }
}
