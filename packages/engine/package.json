{
  "name": "@zveltio/engine",
  "version": "3.0.0-beta.29",
  "private": true,
  "type": "module",
  "scripts": {
    "gen:migrations": "bun scripts/gen-embedded-migrations.ts",
    "build": "bun scripts/gen-embedded-migrations.ts && BUN_MEMORY_LIMIT=4096 bun build src/index.ts --outdir dist --target bun --packages external",
    "build:prod": "bun scripts/gen-embedded-migrations.ts && BUN_MEMORY_LIMIT=2048 bun build src/index.ts --outdir dist --target bun --packages external --minify",
    "dev": "BUN_MEMORY_LIMIT=2048 bun --watch src/index.ts",
    "monitor": "bun watch/index.js",
    "all": "bun dev & bun monitor",
    "start": "bun dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:init": "bun scripts/init-db.ts",
    "cdc:setup": "bun scripts/setup-cdc.ts",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "format": "biome format --write src",
    "format:check": "biome format src",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:unit": "bun test src/tests/unit",
    "test:unit:coverage": "bun test src/tests/unit --coverage --coverage-reporter=lcov --coverage-dir=coverage",
    "test:integration": "bun test src/tests/integration"
  },
  "dependencies": {
    "@better-auth/kysely-adapter": "1.6.23",
    "@better-auth/passkey": "^1.6.23",
    "@hono/zod-validator": "^0.7.6",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@types/pg": "^8.11.0",
    "aws4fetch": "^1.0.20",
    "better-auth": "1.6.23",
    "casbin": "^5.30.0",
    "expr-eval": "^2.0.2",
    "hono": "^4.4.0",
    "imagescript": "^1.3.1",
    "ioredis": "^5.3.2",
    "kysely": "^0.27.6",
    "nodemailer": "^9.0.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.11.0",
    "pg-boss": "^12.18.2",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.17",
    "@zveltio/sdk": "workspace:*",
    "bun-types": "latest",
    "fast-check": "^4.8.0",
    "typescript": "^5.4.0"
  }
}
