{
  "name": "@zveltio/engine",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "build:binary": "bun run scripts/generate-studio-embed.ts && bun build src/index.ts --compile --outfile ../../dist/zveltio --target bun",
    "studio:build": "cd ../studio && bun run build",
    "studio:embed": "bun run scripts/generate-studio-embed.ts",
    "prebuild:binary": "bun run studio:build && cp -r ../studio/build src/studio-dist && bun run studio:embed",
    "test": "bun test",
    "migrate": "bun run src/db/migrate.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@hono/zod-validator": "^0.7.6",
    "better-auth": "^1.3.34",
    "casbin": "^5.30.0",
    "hono": "^4.4.0",
    "ioredis": "^5.3.2",
    "kysely": "^0.27.6",
    "pg": "^8.11.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.4.0"
  }
}
