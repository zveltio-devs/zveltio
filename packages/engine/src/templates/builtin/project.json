        "end_date": "2026-08-31"
      },
      {
        "_key": "p2",
        "name": "Mobile app v1",
        "project_status": "planning",
        "owner": "Elena",
        "start_date": "2026-07-01"
      }
    ],
    "pm_tasks": [
      {
