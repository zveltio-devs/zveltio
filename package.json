{
  "name": "zveltio",
  "version": "1.0.0-alpha.21",
  "private": true,
  "packageManager": "bun@1.2.0",
  "description": "The BaaS that just works — single binary, extensions, no complexity",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:binary": "cd packages/engine && bun run build:binary",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "studio:build": "cd packages/studio && bun run build",
    "studio:embed": "cp -r packages/studio/build packages/engine/src/studio-dist",
    "changeset": "changeset",
    "version-packages": "changeset version && bun run scripts/sync-engine-version.ts",
    "tag": "changeset tag"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "turbo": "^2.0.0",
    "bun-types": "latest",
    "typescript": "^5.4.0",
    "svelte": "^5.0.0",
    "@sveltejs/kit": "^2.5.0",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0"
  },
  "dependencies": {
    "@auth/kysely-adapter": "^1.11.1",
    "kysely": "0.27.6"
  }
}
