{
  "name": "zveltio",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.2.0",
  "description": "The BaaS that just works — single binary, extensions, no complexity",
  "workspaces": [
    "packages/*",
    "extensions/*/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:binary": "cd packages/engine && bun run build:binary",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "studio:build": "cd packages/studio && bun run build",
    "studio:embed": "cp -r packages/studio/build packages/engine/src/studio-dist"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "bun-types": "latest",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@auth/kysely-adapter": "^1.11.1",
    "kysely": "^0.27.6"
  },
  "overrides": {
    "kysely": "0.27.6"
  }
}
