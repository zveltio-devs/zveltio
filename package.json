{
  "name": "zveltio",
  "version": "3.0.0-beta.29",
  "private": true,
  "packageManager": "bun@1.3.13",
  "description": "Self-hosted Business OS — own your hardware, own your data.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:binary": "cd packages/engine && bun run build:binary",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "format": "biome format --write",
    "format:check": "biome format",
    "check": "biome check",
    "check:fix": "biome check --write",
    "check:schema": "bun run scripts/schema-codegen.ts && bun run format && bun run scripts/schema-drift-check.ts",
    "any:ratchet": "bun run scripts/any-ratchet.ts",
    "any:suppress": "bun run scripts/suppress-existing-any.ts",
    "coverage:unit": "cd packages/engine && bun run test:unit:coverage",
    "coverage:gate": "bun run scripts/coverage-gate.ts",
    "prepush": "bun run check:schema && bun run any:ratchet && bun run format:check && bun run typecheck",
    "studio:build": "cd packages/studio && bun run build",
    "studio:embed": "cp -r packages/studio/dist packages/engine/src/studio-dist",
    "changeset": "changeset",
    "version-packages": "changeset version && bun run scripts/sync-engine-version.ts",
    "tag": "changeset tag"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@changesets/cli": "^2.27.0",
    "turbo": "^2.0.0",
    "bun-types": "latest",
    "typescript": "^5.4.0",
    "svelte": "^5.0.0",
    "@sveltejs/kit": "^2.5.0",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0"
  },
  "dependencies": {
    "kysely": "0.27.6"
  },
  "overrides": {
    "@opentelemetry/sdk-trace-base": "2.7.1"
  }
}
